# Copy this file to .env and fill in your values

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/gaia

# Secret used to sign JSON Web Tokens — use a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Mapbox access token used to geocode event locations
# https://account.mapbox.com/access-tokens/
MAP_BOX_KEY=

# Allowed CORS origin for the client app (defaults to * when unset)
CLIENT_ORIGIN=http://localhost:3000

# Port the API listens on (defaults to 4000)
PORT=4000
