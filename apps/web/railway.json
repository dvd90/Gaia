{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build --workspace @gaia/web",
    "watchPatterns": ["apps/web/**", "package.json", "package-lock.json"]
  },
  "deploy": {
    "startCommand": "npm run start --workspace @gaia/web",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
